# Copy to .env (loaded automatically by python-dotenv on startup).
# Set ONE of the following — the recommender will use whichever is configured.

# Anthropic Claude (recommended default — best quality-per-dollar)
# Get a key at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT
# OPENAI_API_KEY=sk-...

# Ollama (local, free) — start `ollama serve` and pull a model first
# OLLAMA_HOST=http://localhost:11434

# Optional overrides
# SHORT_DATA_DIR=                  # where project folders live (default: per-OS user data dir)
# SHORT_FFMPEG=C:\ffmpeg\bin\ffmpeg.exe
# SHORT_FFPROBE=C:\ffmpeg\bin\ffprobe.exe
